# ==============================================
# PersonalMind Pro - Environment Variables
# ==============================================

# === APP CONFIG ===
APP_NAME=PersonalMind Pro
DEBUG=true
ENVIRONMENT=development

# === OpenAI Configuration ===
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-1106-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# === Database ===
DATABASE_URL=postgresql://postgres:change-me-in-production@postgres:5432/personalmind
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=personalmind

# === Redis (Cache & Sessions) ===
REDIS_URL=redis://redis:6379/0

# === Vector Database (ChromaDB) ===
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=/data/vector_db

# === Storage (Documents) ===
STORAGE_MODE=local
LOCAL_STORAGE_PATH=/data/documents

# === Commerce Integration ===
SAMOKAT_API_KEY=mock-api-key
PAPA_JOHNS_API_KEY=mock-api-key

# === Frontend Configuration ===
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_BOT_USERNAME=your-bot-username

# === Backend Configuration ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# === Payment Systems (Future) ===
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
STRIPE_SECRET_KEY=sk-your-stripe-key