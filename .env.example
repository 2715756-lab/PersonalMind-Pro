# === APP CONFIG ===
APP_NAME=PersonalMind Pro
DEBUG=true
ENVIRONMENT=development

# === API KEYS ===
OPENAI_API_KEY=sk-...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# === DATABASE ===
DATABASE_URL=postgresql://user:pass@localhost:5432/personalmind
REDIS_URL=redis://localhost:6379/0

# === VECTOR DB ===
CHROMA_PERSIST_DIR=/data/vector_db
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# === GRAPH DB ===
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# === STORAGE ===
STORAGE_MODE=local  # local или s3
LOCAL_STORAGE_PATH=/data/documents

# S3 (опционально)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=personalmind

# === PAYMENT (для будущего Commerce) ===
YOOKASSA_SHOP_ID=...
YOOKASSA_SECRET_KEY=...
STRIPE_SECRET_KEY=...

# === EXTERNAL APIs (заглушки для начала) ===
SAMOKAT_API_KEY=placeholder
YANDEX_LAVKA_API_KEY=placeholder